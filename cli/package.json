{
    "name": "@design-token-kit/cli",
    "version": "1.3.0",
    "description": "CLI for Design Token Kit: validate, convert, showcase.",
    "keywords": [
        "design-tokens",
        "dtcg",
        "hrdt",
        "tokens",
        "cli",
        "css"
    ],
    "license": "Apache-2.0",
    "homepage": "https://github.com/design-token-kit/design-token-kit",
    "bugs": {
        "url": "https://github.com/design-token-kit/design-token-kit/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/design-token-kit/design-token-kit.git"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "type": "module",
    "bin": {
        "dtokens": "bin/index.mjs"
    },
    "files": [
        "bin"
    ],
    "imports": {
        "#/*": "./src/*"
    },
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "tsc --noEmit && tsup",
        "dist": "node ../scripts/stage-package.mjs cli",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:coverage:v8": "vitest run --coverage --coverage.provider=v8"
    },
    "dependencies": {
        "@design-token-kit/core": "1.3.0",
        "commander": "14.0.1"
    },
    "devDependencies": {
        "@types/node": "24.10.1",
        "@vitest/coverage-istanbul": "4.1.7",
        "@vitest/coverage-v8": "4.1.7",
        "tsup": "8.5.1",
        "typescript": "5.9.3",
        "vitest": "4.1.7"
    }
}
