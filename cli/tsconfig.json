{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "noEmit": true,
        "types": ["node"],
        "baseUrl": ".",
        "paths": {
            "#/*": ["src/*"]
        }
    },
    "include": ["src", "test", "tsup.config.ts", "vitest.config.ts"]
}
