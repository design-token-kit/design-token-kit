{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "primitive": {
    "color": {
      "blue-500": {
        "$type": "color",
        "$value": "#2563EB"
      },
      "blue-600": {
        "$type": "color",
        "$value": 42
      }
    }
  },
  "semantic": {
    "color": {
      "action-primary": {
        "$type": "color",
        "$value": "{primitive.color.blue-500}"
      },
      "action-danger": {
        "$type": "color",
        "$value": "{primitive.color.blue-999}"
      }
    }
  },
  "component": {
    "button": {
      "primary": {
        "background": {
          "$type": "color",
          "$value": "{semantic.color.action-primary}"
        }
      },
      "danger": {
        "background": {
          "$type": "color",
          "$value": "{semantic.color.action-danger}"
        }
      }
    }
  },
  "cycle": {
    "a": {
      "$type": "number",
      "$value": "{cycle.b}"
    },
    "b": {
      "$type": "number",
      "$value": "{cycle.a}"
    }
  }
}

