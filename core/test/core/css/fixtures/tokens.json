{
  "primitive": {
    "color": {
      "white": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [1, 1, 1], "alpha": 1 } },
      "teal": { "500": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.063, 0.647, 0.647], "alpha": 1, "hex": "#10a5a5" } } },
      "overlay": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.4, "hex": "#000000" } },
      "slate": {
        "100": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.945, 0.949, 0.957], "alpha": 1 } },
        "900": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.094, 0.114, 0.145], "alpha": 1 } }
      }
    },
    "spacing": { "4": { "$type": "dimension", "$value": { "value": 16, "unit": "px" } } },
    "transition": { "base": { "$type": "duration", "$value": { "value": 200, "unit": "ms" } } },
    "font": { "weight": { "bold": { "$type": "number", "$value": 700 } } },
    "typography": {
      "body": {
        "$type": "typography",
        "$value": {
          "fontFamily": ["Inter", "Arial", "sans-serif"],
          "fontSize": { "value": 16, "unit": "px" },
          "fontWeight": 500,
          "letterSpacing": { "value": 0, "unit": "px" },
          "lineHeight": 1.5
        }
      }
    },
    "gradient": {
      "brand": {
        "$type": "gradient",
        "$value": [
          { "color": { "colorSpace": "srgb", "components": [0.063, 0.647, 0.647], "alpha": 1, "hex": "#10a5a5" }, "position": 0 },
          { "color": { "colorSpace": "srgb", "components": [0.118, 0.161, 0.231], "alpha": 1 }, "position": 1 }
        ]
      }
    }
  },
  "semantic": {
    "color": {
      "bg": { "surface": { "$type": "color", "$value": "{primitive.color.white}" } },
      "text": { "primary": { "$type": "color", "$value": "{primitive.color.slate.900}" } }
    },
    "text": {
      "body": { "$type": "typography", "$value": "{primitive.typography.body}" }
    },
    "surface": {
      "brand": { "$type": "gradient", "$value": "{primitive.gradient.brand}" }
    }
  },
  "component": {
    "button": {
      "bg": { "$type": "color", "$value": "{semantic.color.bg.surface}" },
      "text": { "$type": "color", "$value": "{semantic.color.text.primary}" }
    }
  }
}
