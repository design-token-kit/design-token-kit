{
    "name": "@design-token-kit/core",
    "version": "1.2.0",
    "description": "Core library for Design Token Kit: validate, convert, showcase.",
    "keywords": [
        "design-tokens",
        "dtcg",
        "tokens",
        "validation",
        "css"
    ],
    "license": "Apache-2.0",
    "homepage": "https://github.com/design-token-kit/design-token-kit",
    "bugs": {
        "url": "https://github.com/design-token-kit/design-token-kit/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/design-token-kit/design-token-kit.git"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "type": "module",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "exports": {
        ".": {
            "development": "./src/index.ts",
            "types": "./lib/index.d.ts",
            "import": "./lib/index.js"
        }
    },
    "imports": {
        "#/*": "./src/*"
    },
    "files": [
        "lib"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "tsc --noEmit && vite build",
        "dist": "node ../scripts/stage-package.mjs core",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:coverage:v8": "vitest run --coverage --coverage.provider=v8"
    },
    "dependencies": {
        "ajv": "8.20.0",
        "ajv-formats": "3.0.1",
        "remark-frontmatter": "5.0.0",
        "remark-parse": "11.0.0",
        "unified": "11.0.5",
        "unist-util-visit": "5.1.0",
        "yaml": "2.9.0"
    },
    "devDependencies": {
        "@microsoft/api-extractor": "7.58.7",
        "@types/node": "24.10.1",
        "@vitest/coverage-istanbul": "4.1.7",
        "@vitest/coverage-v8": "4.1.7",
        "typescript": "5.9.3",
        "vite": "8.0.10",
        "vite-plugin-dts": "5.0.1",
        "vitest": "4.1.7"
    }
}
