{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "primitive": {
    "color": {
      "slate-50": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.9725, 0.9804, 0.9882],
          "alpha": 1,
          "hex": "#f8fafc"
        }
      },
      "slate-100": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.1176, 0.1647, 0.2588],
          "alpha": 1,
          "hex": "#1e2a42"
        }
      },
      "slate-300": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.2039, 0.2549, 0.3490],
          "alpha": 1,
          "hex": "#344159"
        }
      },
      "slate-600": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.7608, 0.8078, 0.8706],
          "alpha": 1,
          "hex": "#c2cede"
        }
      },
      "slate-900": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.0509, 0.0706, 0.1216],
          "alpha": 1,
          "hex": "#0d121f"
        }
      },
      "blue-500": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.3529, 0.4980, 1],
          "alpha": 1,
          "hex": "#5a7fff"
        }
      },
      "blue-600": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.2706, 0.4235, 0.9608],
          "alpha": 1,
          "hex": "#456cf5"
        }
      },
      "cyan-100": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.0824, 0.2392, 0.2784],
          "alpha": 1,
          "hex": "#153d47"
        }
      },
      "cyan-700": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.5608, 0.8980, 0.9569],
          "alpha": 1,
          "hex": "#8fe5f4"
        }
      },
      "surface-base": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.0745, 0.1059, 0.1686],
          "alpha": 1,
          "hex": "#131b2b"
        }
      }
    }
  },
  "semantic": {
    "color": {
      "background": {
        "canvas": {
          "$type": "color",
          "$value": "{primitive.color.slate-900}"
        },
        "surface": {
          "$type": "color",
          "$value": "{primitive.color.surface-base}"
        },
        "subtle": {
          "$type": "color",
          "$value": "{primitive.color.slate-100}"
        }
      },
      "text": {
        "primary": {
          "$type": "color",
          "$value": "{primitive.color.slate-50}"
        },
        "secondary": {
          "$type": "color",
          "$value": "{primitive.color.slate-600}"
        },
        "inverse": {
          "$type": "color",
          "$value": "{primitive.color.slate-50}"
        },
        "accent": {
          "$type": "color",
          "$value": "{primitive.color.cyan-700}"
        }
      },
      "action": {
        "primary": {
          "$type": "color",
          "$value": "{primitive.color.blue-500}"
        },
        "primary-hover": {
          "$type": "color",
          "$value": "{primitive.color.blue-600}"
        }
      },
      "border": {
        "muted": {
          "$type": "color",
          "$value": "{primitive.color.slate-300}"
        }
      },
      "accent": {
        "surface": {
          "$type": "color",
          "$value": "{primitive.color.cyan-100}"
        }
      }
    }
  }
}
