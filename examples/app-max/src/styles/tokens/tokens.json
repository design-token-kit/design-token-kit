{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "primitive": {
    "color": {
      "white": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [1, 1, 1],
          "alpha": 1,
          "hex": "#ffffff"
        }
      },
      "slate-50": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.9725, 0.9804, 0.9882],
          "alpha": 1,
          "hex": "#f8fafc"
        }
      },
      "slate-100": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.9451, 0.9608, 0.9765],
          "alpha": 1,
          "hex": "#f1f5f9"
        }
      },
      "slate-300": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.7961, 0.8353, 0.8824],
          "alpha": 1,
          "hex": "#cbd5e1"
        }
      },
      "slate-600": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.2784, 0.3333, 0.4118],
          "alpha": 1,
          "hex": "#475569"
        }
      },
      "slate-900": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.0588, 0.0902, 0.1647],
          "alpha": 1,
          "hex": "#0f172a"
        }
      },
      "blue-500": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.1451, 0.2863, 0.9647],
          "alpha": 1,
          "hex": "#2549f6"
        }
      },
      "blue-600": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.1137, 0.2235, 0.8549],
          "alpha": 1,
          "hex": "#1d39da"
        }
      },
      "cyan-100": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.8118, 0.9608, 0.9882],
          "alpha": 1,
          "hex": "#cff4fc"
        }
      },
      "cyan-700": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [0.0549, 0.4471, 0.5569],
          "alpha": 1,
          "hex": "#0e728e"
        }
      }
    },
    "dimension": {
      "space-100": {
        "$type": "dimension",
        "$value": {
          "value": 4,
          "unit": "px"
        }
      },
      "space-200": {
        "$type": "dimension",
        "$value": {
          "value": 8,
          "unit": "px"
        }
      },
      "space-300": {
        "$type": "dimension",
        "$value": {
          "value": 12,
          "unit": "px"
        }
      },
      "space-400": {
        "$type": "dimension",
        "$value": {
          "value": 16,
          "unit": "px"
        }
      },
      "space-600": {
        "$type": "dimension",
        "$value": {
          "value": 24,
          "unit": "px"
        }
      },
      "space-800": {
        "$type": "dimension",
        "$value": {
          "value": 32,
          "unit": "px"
        }
      },
      "space-1200": {
        "$type": "dimension",
        "$value": {
          "value": 48,
          "unit": "px"
        }
      },
      "radius-200": {
        "$type": "dimension",
        "$value": {
          "value": 10,
          "unit": "px"
        }
      },
      "radius-300": {
        "$type": "dimension",
        "$value": {
          "value": 16,
          "unit": "px"
        }
      },
      "radius-pill": {
        "$type": "dimension",
        "$value": {
          "value": 999,
          "unit": "px"
        }
      },
      "line-100": {
        "$type": "dimension",
        "$value": {
          "value": 1,
          "unit": "px"
        }
      },
      "measure-article": {
        "$type": "dimension",
        "$value": {
          "value": 1120,
          "unit": "px"
        }
      }
    },
    "fontFamily": {
      "body": {
        "$type": "fontFamily",
        "$value": ["Inter", "Segoe UI", "Arial", "sans-serif"]
      }
    },
    "fontWeight": {
      "regular": {
        "$type": "fontWeight",
        "$value": 400
      },
      "semibold": {
        "$type": "fontWeight",
        "$value": 600
      },
      "bold": {
        "$type": "fontWeight",
        "$value": 700
      }
    },
    "typography": {
      "body-md": {
        "$type": "typography",
        "$value": {
          "fontFamily": ["Inter", "Segoe UI", "Arial", "sans-serif"],
          "fontSize": {
            "value": 16,
            "unit": "px"
          },
          "fontWeight": 400,
          "letterSpacing": {
            "value": 0,
            "unit": "px"
          },
          "lineHeight": 1.6
        }
      },
      "body-lg": {
        "$type": "typography",
        "$value": {
          "fontFamily": ["Inter", "Segoe UI", "Arial", "sans-serif"],
          "fontSize": {
            "value": 18,
            "unit": "px"
          },
          "fontWeight": 400,
          "letterSpacing": {
            "value": 0,
            "unit": "px"
          },
          "lineHeight": 1.6
        }
      },
      "title-xl": {
        "$type": "typography",
        "$value": {
          "fontFamily": ["Inter", "Segoe UI", "Arial", "sans-serif"],
          "fontSize": {
            "value": 40,
            "unit": "px"
          },
          "fontWeight": 700,
          "letterSpacing": {
            "value": -1,
            "unit": "px"
          },
          "lineHeight": 1.1
        }
      },
      "title-md": {
        "$type": "typography",
        "$value": {
          "fontFamily": ["Inter", "Segoe UI", "Arial", "sans-serif"],
          "fontSize": {
            "value": 22,
            "unit": "px"
          },
          "fontWeight": 600,
          "letterSpacing": {
            "value": -0.3,
            "unit": "px"
          },
          "lineHeight": 1.2
        }
      },
      "label-sm": {
        "$type": "typography",
        "$value": {
          "fontFamily": ["Inter", "Segoe UI", "Arial", "sans-serif"],
          "fontSize": {
            "value": 13,
            "unit": "px"
          },
          "fontWeight": 600,
          "letterSpacing": {
            "value": 0.2,
            "unit": "px"
          },
          "lineHeight": 1.4
        }
      }
    }
  },
  "semantic": {
    "color": {
      "background": {
        "canvas": {
          "$type": "color",
          "$value": "{primitive.color.slate-50}"
        },
        "surface": {
          "$type": "color",
          "$value": "{primitive.color.white}"
        },
        "subtle": {
          "$type": "color",
          "$value": "{primitive.color.slate-100}"
        }
      },
      "text": {
        "primary": {
          "$type": "color",
          "$value": "{primitive.color.slate-900}"
        },
        "secondary": {
          "$type": "color",
          "$value": "{primitive.color.slate-600}"
        },
        "inverse": {
          "$type": "color",
          "$value": "{primitive.color.slate-50}"
        },
        "accent": {
          "$type": "color",
          "$value": "{primitive.color.cyan-700}"
        }
      },
      "action": {
        "primary": {
          "$type": "color",
          "$value": "{primitive.color.blue-500}"
        },
        "primary-hover": {
          "$type": "color",
          "$value": "{primitive.color.blue-600}"
        }
      },
      "border": {
        "muted": {
          "$type": "color",
          "$value": "{primitive.color.slate-300}"
        }
      },
      "accent": {
        "surface": {
          "$type": "color",
          "$value": "{primitive.color.cyan-100}"
        }
      }
    },
    "dimension": {
      "space": {
        "xs": {
          "$type": "dimension",
          "$value": "{primitive.dimension.space-100}"
        },
        "sm": {
          "$type": "dimension",
          "$value": "{primitive.dimension.space-200}"
        },
        "md": {
          "$type": "dimension",
          "$value": "{primitive.dimension.space-400}"
        },
        "lg": {
          "$type": "dimension",
          "$value": "{primitive.dimension.space-600}"
        },
        "xl": {
          "$type": "dimension",
          "$value": "{primitive.dimension.space-800}"
        },
        "xxl": {
          "$type": "dimension",
          "$value": "{primitive.dimension.space-1200}"
        }
      },
      "radius": {
        "card": {
          "$type": "dimension",
          "$value": "{primitive.dimension.radius-300}"
        },
        "control": {
          "$type": "dimension",
          "$value": "{primitive.dimension.radius-200}"
        },
        "pill": {
          "$type": "dimension",
          "$value": "{primitive.dimension.radius-pill}"
        }
      },
      "line": {
        "default": {
          "$type": "dimension",
          "$value": "{primitive.dimension.line-100}"
        }
      },
      "measure": {
        "page": {
          "$type": "dimension",
          "$value": "{primitive.dimension.measure-article}"
        }
      }
    },
    "typography": {
      "body": {
        "$type": "typography",
        "$value": "{primitive.typography.body-md}"
      },
      "lead": {
        "$type": "typography",
        "$value": "{primitive.typography.body-lg}"
      },
      "title-lg": {
        "$type": "typography",
        "$value": "{primitive.typography.title-xl}"
      },
      "title-md": {
        "$type": "typography",
        "$value": "{primitive.typography.title-md}"
      },
      "label": {
        "$type": "typography",
        "$value": "{primitive.typography.label-sm}"
      }
    },
    "fontFamily": {
      "body": {
        "$type": "fontFamily",
        "$value": "{primitive.fontFamily.body}"
      }
    },
    "fontWeight": {
      "strong": {
        "$type": "fontWeight",
        "$value": "{primitive.fontWeight.semibold}"
      }
    }
  },
  "component": {
    "button": {
      "bg": {
        "$type": "color",
        "$value": "{semantic.color.action.primary}"
      },
      "bg-hover": {
        "$type": "color",
        "$value": "{semantic.color.action.primary-hover}"
      },
      "text": {
        "$type": "color",
        "$value": "{semantic.color.text.inverse}"
      },
      "border": {
        "$type": "color",
        "$value": "{semantic.color.border.muted}"
      },
      "radius": {
        "$type": "dimension",
        "$value": "{semantic.dimension.radius.control}"
      },
      "padding-inline": {
        "$type": "dimension",
        "$value": "{semantic.dimension.space.lg}"
      },
      "padding-block": {
        "$type": "dimension",
        "$value": "{semantic.dimension.space.sm}"
      }
    },
    "card": {
      "bg": {
        "$type": "color",
        "$value": "{semantic.color.background.surface}"
      },
      "border": {
        "$type": "color",
        "$value": "{semantic.color.border.muted}"
      },
      "radius": {
        "$type": "dimension",
        "$value": "{semantic.dimension.radius.card}"
      },
      "padding": {
        "$type": "dimension",
        "$value": "{semantic.dimension.space.xl}"
      }
    },
    "badge": {
      "bg": {
        "$type": "color",
        "$value": "{semantic.color.accent.surface}"
      },
      "text": {
        "$type": "color",
        "$value": "{semantic.color.text.accent}"
      },
      "radius": {
        "$type": "dimension",
        "$value": "{semantic.dimension.radius.pill}"
      },
      "padding-inline": {
        "$type": "dimension",
        "$value": "{semantic.dimension.space.md}"
      },
      "padding-block": {
        "$type": "dimension",
        "$value": "{semantic.dimension.space.xs}"
      }
    }
  }
}
