{
    "name": "design-token-kit",
    "private": true,
    "version": "0.2.0",
    "workspaces": [
        "core",
        "cli"
    ],
    "scripts": {
        "build": "npm run build --workspace @design-token-kit/core && npm run build --workspace @design-token-kit/cli",
        "dist": "npm run build && npm run dist --workspace @design-token-kit/core && npm run dist --workspace @design-token-kit/cli",
        "test": "npm run test --workspace @design-token-kit/core",
        "clean": "node scripts/clean.mjs",
        "dtokens": "node --import tsx --conditions development cli/src/index.ts",
        "release:prepare": "node scripts/release-prepare.mjs",
        "release:publish": "node scripts/release-publish.mjs"
    },
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "tsx": "4.22.4"
    }
}
